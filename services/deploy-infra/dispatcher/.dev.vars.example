# Local development environment variables
# Copy this file to .dev.vars and update with your actual values

# JWT secret for signing auth cookies (required)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-at-least-32-bytes-long

# Session duration in seconds for JWT tokens
# Optional: already configured in wrangler.jsonc
SESSION_DURATION_SECONDS=604800

# Backend authentication token for Management API endpoints (required)
# Used by the web app and builder to authenticate dispatcher API requests
# @from USER_DEPLOYMENTS_DISPATCHER_AUTH_KEY
BACKEND_AUTH_TOKEN=
