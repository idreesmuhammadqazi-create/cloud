# MCP Gateway Worker local development secrets and values.
#
# These values are test-only and are intentionally safe to commit in the example.
# Wrangler loads these as ordinary local Worker secrets from .dev.vars.
# Replace them before using a local gateway against anything other than local fixtures.
#
# Copy this file to .dev.vars to boot the Worker locally:
#   cp .dev.vars.example .dev.vars
#
# Generate a fresh matching bundle with:
#   pnpm --filter cloudflare-mcp-gateway keys:generate -- --format env --target worker --issuer http://localhost:3000
#
# For end-to-end app + Worker smoke tests, configure apps/web/.env.local with a
# matching MCP_GATEWAY_JWT_PRIVATE_KEYSET_JSON, MCP_GATEWAY_CREDENTIAL_KEYSET_JSON,
# and MCP_GATEWAY_RATE_LIMIT_SECRET. The Worker only needs the public JWKS and
# decrypt-capable credential keyset below.
#
# Hyperdrive is configured in wrangler.jsonc. For local Postgres development,
# the binding uses the local connection string declared there.

# Local app origin that owns the first-level OAuth authorization server.
APP_BASE_URL='http://localhost:3000'

# Local Worker origin used for canonical MCP resources and JWT audiences.
# apps/web must use the same value for MCP_GATEWAY_BASE_URL in local end-to-end flows.
MCP_GATEWAY_BASE_URL='http://localhost:8806'

# These dev vars pair with the dev vars in .env.local. Worker keyset values stay
# raw JSON for Wrangler compatibility. App-side keyset values are base64-encoded
# JSON when generated for Vercel.
